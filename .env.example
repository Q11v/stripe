# Stripe API keys — get them from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx

# Webhook signing secret. When testing locally with the Stripe CLI, run
#   stripe listen --forward-to localhost:3040/api/webhook
# and copy the "whsec_..." value it prints here.
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Base URL of this app, used to build the Elements return_url after payment.
NEXT_PUBLIC_APP_URL=http://localhost:3040
